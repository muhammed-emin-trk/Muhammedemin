# ─── PostgreSQL (Vercel Postgres veya Neon.tech) ─────────────────────
# Vercel Dashboard → Storage → Postgres → Connect
DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Admin Paneli ────────────────────────────────────────────────────
# Admin giriş şifresi (değiştirmeniz önerilir)
ADMIN_PASSWORD=emin2026

# ─── Oturum Güvenliği ────────────────────────────────────────────────
# En az 32 karakter rastgele bir değer girin
# Örnek: openssl rand -hex 32
SESSION_SECRET=change_this_to_a_random_32_char_string_minimum

# ─── Site URL (SEO için opsiyonel) ───────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.muhammedeminturk.com.tr
